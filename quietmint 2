<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiet Mint</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Instrument+Serif:italic&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F5FAF8; margin: 0; }
        .serif { font-family: 'Instrument Serif', serif; }
        .glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const QuietMintApp = () => {
            const [step, setStep] = useState(0);
            const [formData, setFormData] = useState({
                balance: '',
                goalName: '',
                monthlyGoal: ''
            });
            const [isActive, setIsActive] = useState(false);

            // Check if user already finished onboarding
            useEffect(() => {
                const saved = localStorage.getItem('quiet_mint_user');
                if (saved) {
                    setFormData(JSON.parse(saved));
                    setIsActive(true);
                }
            }, []);

            const saveAndStart = () => {
                localStorage.setItem('quiet_mint_user', JSON.stringify(formData));
                setIsActive(true);
            };

            const reset = () => {
                localStorage.removeItem('quiet_mint_user');
                window.location.reload();
            };

            // Calculate Daily Spend
            const getDaily = () => {
                const bal = parseFloat(formData.balance) || 0;
                const goal = parseFloat(formData.monthlyGoal) || 0;
                return ((bal - goal) / 30).toFixed(2);
            };

            // --- ONBOARDING FLOW ---
            if (!isActive) {
                return (
                    <div className="min-h-screen flex items-center justify-center p-6">
                        <div className="max-w-md w-full bg-white p-10 rounded-[3rem] shadow-2xl">
                            {step === 0 && (
                                <div className="animate-in fade-in duration-500">
                                    <h2 className="text-3xl serif italic mb-6 text-[#1A2E26]">What is your current bank balance?</h2>
                                    <input type="number" placeholder="$0.00" className="text-4xl w-full border-b border-gray-200 outline-none pb-2 mb-8" 
                                        value={formData.balance} onChange={e => setFormData({...formData, balance: e.target.value})} />
                                    <button onClick={() => setStep(1)} className="w-full bg-[#2D4F44] text-white py-4 rounded-full font-bold">NEXT</button>
                                </div>
                            )}
                            {step === 1 && (
                                <div className="animate-in fade-in duration-500">
                                    <h2 className="text-3xl serif italic mb-6 text-[#1A2E26]">What are you saving for?</h2>
                                    <input type="text" placeholder="Tokyo Trip, New Car..." className="text-3xl w-full border-b border-gray-200 outline-none pb-2 mb-8" 
                                        value={formData.goalName} onChange={e => setFormData({...formData, goalName: e.target.value})} />
                                    <button onClick={() => setStep(2)} className="w-full bg-[#2D4F44] text-white py-4 rounded-full font-bold">NEXT</button>
                                </div>
                            )}
                            {step === 2 && (
                                <div className="animate-in fade-in duration-500">
                                    <h2 className="text-3xl serif italic mb-6 text-[#1A2E26]">Monthly savings goal for {formData.goalName}?</h2>
                                    <input type="number" placeholder="$0.00" className="text-4xl w-full border-b border-gray-200 outline-none pb-2 mb-8" 
                                        value={formData.monthlyGoal} onChange={e => setFormData({...formData, monthlyGoal: e.target.value})} />
                                    <button onClick={saveAndStart} className="w-full bg-[#2D4F44] text-white py-4 rounded-full font-bold">FINISH & START LIVING</button>
                                </div>
                            )}
                        </div>
                    </div>
                );
            }

            // --- MAIN APP ---
            return (
                <div className="min-h-screen p-8 max-w-lg mx-auto text-[#1A2E26]">
                    <div className="flex justify-between items-center mb-12">
                        <h1 className="text-2xl serif italic tracking-tight">Quiet Mint</h1>
                        <button onClick={reset} className="text-[10px] uppercase tracking-widest opacity-30 font-bold hover:opacity-100">Reset</button>
                    </div>

                    <div className="bg-[#2D4F44] text-white p-8 rounded-[2.5rem] shadow-xl mb-12">
                        <p className="text-[10px] tracking-widest opacity-50 mb-2 uppercase">The Whisper</p>
                        <p className="text-xl font-light leading-relaxed italic">
                            "Everything is handled, Alex. I've secured your ${formData.monthlyGoal} for {formData.goalName}. Here is what you can spend today."
                        </p>
                    </div>

                    <div className="text-center mb-16">
                        <p className="text-[10px] tracking-[0.4em] opacity-40 uppercase mb-2 font-bold">Daily Allowance</p>
                        <h2 className="text-8xl serif italic tracking-tighter">${getDaily()}</h2>
                    </div>

                    <div className="glass p-6 rounded-[2rem] flex justify-between items-center mb-32">
                        <div className="flex items-center gap-4">
                            <div className="w-10 h-10 bg-[#B4E8D1] rounded-xl flex items-center justify-center">🎁</div>
                            <div>
                                <h4 className="font-bold text-sm">{formData.goalName}</h4>
                                <p className="text-[10px] opacity-40 uppercase tracking-widest font-bold">Auto-Sweep Active</p>
                            </div>
                        </div>
                        <p className="font-bold text-green-600">-${formData.monthlyGoal}</p>
                    </div>

                    <div className="fixed bottom-10 left-6 right-6 max-w-md mx-auto bg-white p-5 rounded-full shadow-2xl flex items-center justify-between px-10">
                        <span className="text-xs font-bold tracking-widest opacity-40 uppercase">Safe Mode</span>
                        <div className="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<QuietMintApp />);
    </script>
</body>
</html>
